# tasks server configuration. Copy to .env and edit.
# Every setting also has an equivalent --flag (flags override env).

# --- core ---
TASKS_ADDR=127.0.0.1:7842          # listen address (use 0.0.0.0 in containers)
TASKS_DB=data/tasks.db             # SQLite path (the single source of truth)
TASKS_PREFIX=                      # issue id prefix; derived from imported data if empty
TASKS_ACTOR=agent                  # default actor recorded on writes

# --- auth (REQUIRED for any non-loopback / funnel exposure) ---
# Generate: openssl rand -hex 32
TASKS_TOKEN=
# TASKS_TOKEN_FILE=/run/secrets/tasks_token   # read token from a file instead
# TASKS_ALLOW_NO_AUTH=false        # allow running unauthenticated on a public bind (danger)

# --- data backup ---
TASKS_EXPORT=                      # mirror the store to this issues.jsonl on change
TASKS_EXPORT_INTERVAL=15s          # debounce window for exports
TASKS_GIT=false                    # git add+commit the export
TASKS_GIT_PUSH=false               # also git push

# --- logging ---
TASKS_LOG_LEVEL=info               # debug|info|warn|error
TASKS_LOG_FORMAT=text              # text|json (use json in production)

# --- HTTP hardening ---
TASKS_READ_TIMEOUT=15s
TASKS_WRITE_TIMEOUT=30s
TASKS_IDLE_TIMEOUT=120s
TASKS_SHUTDOWN_TIMEOUT=10s
TASKS_MAX_BODY_BYTES=1048576       # 1 MiB request body cap
TASKS_RATE_LIMIT=20                # per-IP requests/sec (0 disables)
TASKS_RATE_BURST=40                # per-IP burst
TASKS_BEHIND_PROXY=false           # trust X-Forwarded-For (only behind a trusted proxy)
TASKS_CORS_ORIGINS=                # comma-separated allowed CORS origins (empty = same-origin)
TASKS_METRICS=true                 # expose /metrics (Prometheus)

# --- CLI (tasks / bd) ---
# TASKS_URL=http://127.0.0.1:7842  # where the CLI reaches the server
# TASKS_TOKEN is shared with the CLI for auth
